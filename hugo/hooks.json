[
  {
    "id": "redeploy",
    "execute-command": "/run.sh",
    "pass-arguments-to-command": [
        { "source": "string", "name": "webhook" }
    ],
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "${WEBHOOK_SECRET}",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature-256"
        }
      }
    }
  }
]
